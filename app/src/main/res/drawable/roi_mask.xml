<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fondo con viñeta sutil -->
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:endColor="#1A000000"
                android:startColor="#0D000000" />
        </shape>
    </item>

    <!-- ROI con sombra interior -->
    <item>
        <shape>
            <solid android:color="#00000000" />
            <stroke
                android:width="2dp"
                android:color="#55554C" />
            <corners android:radius="30dp" />
            <size
                android:width="280dp"
                android:height="120dp" />
        </shape>
    </item>

    <!-- Sombra exterior (efecto profundidad) -->
    <item>
        <shape>
            <solid android:color="#00000000" />
            <stroke
                android:width="20dp"
                android:color="#15FFFFFF" />
            <corners android:radius="5dp" />
            <size
                android:width="300dp"
                android:height="140dp" />
        </shape>
    </item>
</layer-list>